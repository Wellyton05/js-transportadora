---
// TrackingSection.astro — Rastreio de Carga via WhatsApp
---

<section id="tracking" class="relative py-20 bg-navy overflow-hidden">
  <!-- Background elements -->
  <div class="absolute inset-0 bg-diagonal-lines opacity-30"></div>
  <div class="absolute inset-0 bg-grid opacity-10"></div>
  
  <!-- Diagonal cuts -->
  <div class="absolute top-0 left-0 w-full h-16 bg-white" style="clip-path: polygon(0 0, 100% 0, 100% 0, 0 100%);"></div>
  <div class="absolute bottom-0 left-0 w-full h-16 bg-silver-50" style="clip-path: polygon(0 100%, 100% 0, 100% 100%);"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="reveal space-y-8">
      <!-- Animated icon -->
      <div class="w-20 h-20 mx-auto bg-accent/10 border border-accent/30 rounded-full flex items-center justify-center animate-pulse-slow">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
      </div>

      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Rastreie sua carga em <span class="text-accent">tempo real</span>
        </h2>
        <p class="text-silver-300 text-lg max-w-2xl mx-auto">
          Saiba exatamente onde sua mercadoria está. Entre em contato com nossa equipe via WhatsApp e receba a atualização instantânea do rastreamento.
        </p>
      </div>

      <a
        href="https://wa.me/5547988602569"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary inline-flex text-lg px-10 py-5"
        id="tracking-cta"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Rastrear minha Carga
      </a>

      <!-- Trust indicators -->
      <div class="flex flex-wrap justify-center gap-8 pt-6">
        <div class="flex items-center gap-2 text-silver-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="text-sm">Resposta rápida</span>
        </div>
        <div class="flex items-center gap-2 text-silver-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="text-sm">Sem burocracia</span>
        </div>
        <div class="flex items-center gap-2 text-silver-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="text-sm">Atualização em tempo real</span>
        </div>
      </div>
    </div>
  </div>
</section>
