---
// CoverageSection.astro — Área de Atuação
const mainCities = [
  { name: 'Itajaí', highlight: true, description: 'Sede — Centro logístico e portuário' },
  { name: 'Balneário Camboriú', highlight: true, description: 'Atendimento completo na região' },
  { name: 'Navegantes', highlight: true, description: 'Próximo ao aeroporto e zona industrial' },
];

const otherCities = [
  'Brusque', 'Camboriú', 'Penha', 'Piçarras',
  'Ilhota', 'Gaspar', 'Blumenau', 'Joinville',
  'Florianópolis', 'São José', 'Palhoça', 'Tijucas',
  'Biguaçu', 'Jaraguá do Sul', 'Indaial', 'Pomerode',
];
---

<section id="coverage" class="relative py-24 lg:py-32 bg-navy overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-diagonal-lines opacity-20"></div>
  <div class="absolute inset-0 bg-grid opacity-5"></div>
  
  <!-- Diagonal top -->
  <div class="absolute top-0 left-0 w-full h-20 bg-white" style="clip-path: polygon(0 0, 100% 0, 100% 0, 0 100%);"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-2 mb-4">
        <div class="w-10 h-[2px] bg-accent"></div>
        <span class="text-accent font-semibold text-sm uppercase tracking-widest">Área de Atuação</span>
        <div class="w-10 h-[2px] bg-accent"></div>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Presentes onde você <span class="text-accent">precisa</span>
      </h2>
      <p class="text-silver-300 text-lg max-w-2xl mx-auto">
        Cobertura estratégica no litoral e Vale do Itajaí, com expansão para todo o estado de Santa Catarina.
      </p>
    </div>

    <!-- Main Cities -->
    <div class="grid md:grid-cols-3 gap-6 mb-12">
      {mainCities.map((city, index) => (
        <div class={`reveal delay-${(index + 1) * 100} group`}>
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 hover:border-accent/40 rounded-sm p-6 text-center transition-all duration-300 hover:bg-white/10">
            <!-- Pin Icon -->
            <div class="w-12 h-12 mx-auto mb-4 bg-accent/15 rounded-full flex items-center justify-center group-hover:bg-accent/25 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <h3 class="text-white font-bold text-xl mb-1">{city.name}</h3>
            <p class="text-silver-400 text-sm">{city.description}</p>
            {city.name === 'Itajaí' && (
              <span class="inline-block mt-3 text-[10px] font-bold uppercase tracking-widest text-accent bg-accent/10 px-3 py-1 rounded-sm">
                Sede
              </span>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Other Cities -->
    <div class="reveal delay-400">
      <div class="text-center mb-6">
        <span class="text-silver-400 text-sm uppercase tracking-wider">Também atendemos</span>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {otherCities.map((city) => (
          <span class="px-4 py-2 bg-white/5 border border-white/8 text-silver-300 text-sm rounded-sm hover:bg-white/10 hover:text-white hover:border-accent/30 transition-all duration-200 cursor-default">
            {city}
          </span>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-12 reveal delay-500">
      <p class="text-silver-400 mb-4 text-sm">Sua cidade não está na lista? Entre em contato — provavelmente atendemos!</p>
      <a
        href="https://wa.me/5547988602569"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary inline-flex"
      >
        Consultar Atendimento
      </a>
    </div>
  </div>

  <!-- Diagonal bottom -->
  <div class="absolute bottom-0 left-0 w-full h-20 bg-silver-50" style="clip-path: polygon(0 100%, 100% 0, 100% 100%);"></div>
</section>
