---
// ContactSection.astro — Formulário de contato + WhatsApp
---

<section id="contact" class="relative py-24 lg:py-32 bg-silver-50 overflow-hidden">
  <!-- Decorative -->
  <div class="absolute inset-0 bg-diagonal-lines opacity-20"></div>
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-silver-300 to-transparent"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-2 mb-4">
        <div class="w-10 h-[2px] bg-accent"></div>
        <span class="text-accent font-semibold text-sm uppercase tracking-widest">Fale Conosco</span>
        <div class="w-10 h-[2px] bg-accent"></div>
      </div>
      <h2 class="section-title text-center">
        Entre em contato<br />e <span class="text-accent">resolva seu frete</span>
      </h2>
      <p class="section-subtitle mx-auto text-center">
        Estamos prontos para atender sua demanda. Preencha o formulário ou chame no WhatsApp.
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-12">
      <!-- Contact Form — 3 cols -->
      <div class="lg:col-span-3 reveal-left">
        <form id="contact-form" class="bg-white border border-silver-200 rounded-sm p-8 space-y-6 shadow-sm">
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-semibold text-navy mb-2">Nome completo</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-silver-50 border border-silver-200 rounded-sm text-gray-800 placeholder-silver-400 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/30 transition-colors"
                placeholder="Seu nome"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-navy mb-2">E-mail</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-silver-50 border border-silver-200 rounded-sm text-gray-800 placeholder-silver-400 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/30 transition-colors"
                placeholder="seu@email.com"
              />
            </div>
          </div>

          <div>
            <label for="phone" class="block text-sm font-semibold text-navy mb-2">Telefone / WhatsApp</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-4 py-3 bg-silver-50 border border-silver-200 rounded-sm text-gray-800 placeholder-silver-400 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/30 transition-colors"
              placeholder="(47) 99999-9999"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-navy mb-2">Mensagem</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="w-full px-4 py-3 bg-silver-50 border border-silver-200 rounded-sm text-gray-800 placeholder-silver-400 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/30 transition-colors resize-none"
              placeholder="Descreva sua necessidade de transporte..."
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full justify-center" id="contact-submit-btn">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
            Enviar Mensagem
          </button>
        </form>
      </div>

      <!-- Contact Info — 2 cols -->
      <div class="lg:col-span-2 space-y-6 reveal-right">
        <!-- WhatsApp Cards -->
        <div class="space-y-4">
          <h3 class="text-lg font-bold text-navy">Atendimento via WhatsApp</h3>
          
          <a
            href="https://wa.me/5547988602569"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-4 bg-white border border-silver-200 rounded-sm hover:border-[#25D366]/50 hover:shadow-md transition-all group"
            id="contact-whatsapp-1"
          >
            <div class="w-12 h-12 bg-[#25D366]/10 rounded-full flex items-center justify-center group-hover:bg-[#25D366]/20 transition-colors flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <span class="text-navy font-bold block">(47) 98860-2569</span>
              <span class="text-gray-500 text-sm">Operacional / Rastreio</span>
            </div>
          </a>

          <a
            href="https://wa.me/5547997848201"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-4 bg-white border border-silver-200 rounded-sm hover:border-[#25D366]/50 hover:shadow-md transition-all group"
            id="contact-whatsapp-2"
          >
            <div class="w-12 h-12 bg-[#25D366]/10 rounded-full flex items-center justify-center group-hover:bg-[#25D366]/20 transition-colors flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <span class="text-navy font-bold block">(47) 99784-8201</span>
              <span class="text-gray-500 text-sm">Suporte</span>
            </div>
          </a>
        </div>

        <!-- Address -->
        <div class="bg-white border border-silver-200 rounded-sm p-6 space-y-4">
          <h3 class="text-lg font-bold text-navy flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            Endereço
          </h3>
          <div class="text-gray-600 text-sm space-y-1">
            <p class="font-semibold text-navy">Rua Odilio Garcia, 520</p>
            <p>Cordeiros, Itajaí — SC</p>
          </div>
        </div>

        <!-- Hours -->
        <div class="bg-white border border-silver-200 rounded-sm p-6 space-y-4">
          <h3 class="text-lg font-bold text-navy flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            Horário de Atendimento
          </h3>
          <div class="text-gray-600 text-sm space-y-1">
            <div class="flex justify-between">
              <span>Segunda a Sexta</span>
              <span class="font-semibold text-navy">08:00 — 18:00</span>
            </div>
            <div class="flex justify-between">
              <span>Urgências</span>
              <span class="font-semibold text-accent">24h via WhatsApp</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const btn = document.getElementById('contact-submit-btn') as HTMLButtonElement | null;

  const ICON_SEND = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>`;
  const ICON_CHECK = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
  const ICON_ERROR = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>`;

  function resetBtn() {
    if (!btn) return;
    btn.disabled = false;
    btn.innerHTML = `${ICON_SEND} Enviar Mensagem`;
    btn.className = btn.className
      .replace(/bg-green-500|bg-red-500/g, '')
      .trim();
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn) return;

    btn.disabled = true;
    btn.innerHTML = `<svg class="w-5 h-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg> Enviando...`;

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });

      if (res.ok) {
        btn.innerHTML = `${ICON_CHECK} Mensagem Enviada!`;
        btn.classList.add('bg-green-500');
        form.reset();
        setTimeout(resetBtn, 4000);
      } else {
        const json = await res.json().catch(() => ({}));
        btn.innerHTML = `${ICON_ERROR} ${(json as any).error ?? 'Erro ao enviar. Tente novamente.'}`;
        btn.classList.add('bg-red-500');
        setTimeout(resetBtn, 5000);
      }
    } catch {
      btn.innerHTML = `${ICON_ERROR} Sem conexão. Tente novamente.`;
      btn.classList.add('bg-red-500');
      setTimeout(resetBtn, 5000);
    }
  });
</script>
