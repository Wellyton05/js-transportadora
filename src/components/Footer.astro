---
// Footer.astro
import { Image } from 'astro:assets';
import logoMini from '../assets/imagemJS.png';
const currentYear = new Date().getFullYear();
---

<footer class="relative bg-navy-800 pt-16 pb-8 overflow-hidden">
  <!-- Decorative -->
  <div class="absolute inset-0 bg-diagonal-lines opacity-10"></div>
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-4 gap-12 mb-12">
      <!-- Brand -->
      <div class="md:col-span-2 space-y-4">
        <div class="flex items-center gap-3">
          <Image 
            src={logoMini} 
            alt="Iniciais J.S Transportadora" 
            class="h-12 w-auto object-contain shrink-0"
            quality="max"
          />
          <div>
            <span class="block text-white font-bold text-lg leading-tight">J.S Transportadora</span>
            <span class="block text-silver-400 text-xs uppercase tracking-[0.25em]">Itajaí — SC</span>
          </div>
        </div>
        <p class="text-silver-400 text-sm leading-relaxed max-w-md">
          Transporte de cargas com segurança, agilidade e atendimento personalizado. Sua carga em boas mãos, do início ao destino.
        </p>
        <div class="flex gap-3 pt-2">
          <a
            href="https://wa.me/5547988602569"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/5 border border-white/10 rounded-sm flex items-center justify-center text-silver-400 hover:bg-[#25D366]/20 hover:text-[#25D366] hover:border-[#25D366]/30 transition-all"
            aria-label="WhatsApp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="space-y-4">
        <h4 class="text-white font-bold text-sm uppercase tracking-wider">Navegação</h4>
        <nav class="flex flex-col gap-2">
          <a href="#home" class="text-silver-400 text-sm hover:text-accent transition-colors">Início</a>
          <a href="#about" class="text-silver-400 text-sm hover:text-accent transition-colors">A Empresa</a>
          <a href="#services" class="text-silver-400 text-sm hover:text-accent transition-colors">Serviços</a>
          <a href="#fleet" class="text-silver-400 text-sm hover:text-accent transition-colors">Nossa Frota</a>
          <a href="#coverage" class="text-silver-400 text-sm hover:text-accent transition-colors">Área de Atuação</a>
          <a href="#contact" class="text-silver-400 text-sm hover:text-accent transition-colors">Contato</a>
        </nav>
      </div>

      <!-- Services -->
      <div class="space-y-4">
        <h4 class="text-white font-bold text-sm uppercase tracking-wider">Serviços</h4>
        <nav class="flex flex-col gap-2">
          <a href="#services" class="text-silver-400 text-sm hover:text-accent transition-colors">Carga Dedicada / Fechada</a>
          <a href="#services" class="text-silver-400 text-sm hover:text-accent transition-colors">Complementos</a>
          <a href="#tracking" class="text-silver-400 text-sm hover:text-accent transition-colors">Rastreio de Carga</a>
        </nav>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-silver-500 text-xs">
        &copy; {currentYear} J.S Transportadora. Todos os direitos reservados.
      </p>
      <p class="text-silver-500/50 text-xs">
        CNPJ: 65.311.352/0001-03
      </p>
    </div>
  </div>
</footer>
