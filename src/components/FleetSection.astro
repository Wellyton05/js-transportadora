---
// FleetSection.astro — Frota: 2 Ducatos + 1 Fiorino
import { Image } from 'astro:assets';
import ducato1Front from '../assets/ducato-1.jpeg';
import ducato1Rear from '../assets/ducato-1-traseira.jpeg';
import ducato1Box from '../assets/ducato-1-bau.jpeg';

import ducato2Front from '../assets/ducato-2.jpeg';
import ducato2Rear from '../assets/ducato-2-traseira.jpeg';
import ducato2Box from '../assets/ducato-2-bau.jpeg';

import fiorino1 from '../assets/fiorino-1.jpeg';
import fiorino2 from '../assets/fiorino-2.jpeg';

const vehicles = [
  {
    name: 'Fiat Ducato',
    unit: 'Veículo 01',
    type: 'Van de Carga',
    spec: 'DUCATO MÁXI LONG 2.3 T.ALTO DIESEL - 3 PALLETS',
    capacity: 'Carga máxima: 1.5 toneladas',
    description: 'Veículo ideal para entregas ágeis, oferecendo versatilidade para rotas urbanas e regionais com máxima segurança para sua carga.',
    images: [ducato1Front, ducato1Rear, ducato1Box],
  },
  {
    name: 'Fiat Ducato',
    unit: 'Veículo 02',
    type: 'Van de Carga',
    spec: 'DUCATO MÁXI LONG 2.3 T.ALTO DIESEL - 3 PALLETS',
    capacity: 'Carga máxima: 1.5 toneladas',
    description: 'Veículo ideal para entregas ágeis, oferecendo versatilidade para rotas urbanas e regionais com máxima segurança para sua carga.',
    images: [ducato2Front, ducato2Rear, ducato2Box],
  },
  {
    name: 'Fiat Fiorino',
    unit: 'Veículo 03',
    type: 'Furgão Compacto',
    spec: 'FIORINO FURGÃO 1.4 EVO FLEX 8V - CARGA URBANA',
    capacity: 'Carga máxima: 680 kg',
    description: 'Ideal para entregas urbanas rápidas e locais de difícil acesso, com agilidade, economia e praticidade no dia a dia.',
    images: [fiorino1, fiorino2],
  },
];
---

<section id="fleet" class="relative py-24 lg:py-32 bg-white overflow-hidden">
  <!-- Decorative top line -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-silver-300 to-transparent"></div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-16 reveal">
      <div class="inline-flex items-center gap-2 mb-4">
        <div class="w-10 h-[2px] bg-accent"></div>
        <span class="text-accent font-semibold text-sm uppercase tracking-widest">Nossa Frota</span>
      </div>
      <h2 class="section-title">
        Agilidade e segurança<br />
        <span class="text-accent">na medida certa</span>
      </h2>
      <p class="section-subtitle">
        Nossa frota de Ducatos e Fiorino é ideal para entregas ágeis com a segurança que sua carga merece.
      </p>
    </div>

    <!-- Fleet Grid — 2 Ducatos + 1 Fiorino -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {vehicles.map((vehicle, index) => (
        <div class={`reveal delay-${(index + 1) * 200}`}>
          <div class="bg-silver-50 border border-silver-200 rounded-sm overflow-hidden hover:border-accent/40 transition-all duration-500 group">
            <!-- Vehicle Images Carousel -->
            <div class="relative h-56 bg-navy overflow-hidden group">
              <!-- Scroll Container -->
              <div class="flex overflow-x-auto snap-x snap-mandatory hide-scrollbar h-full w-full" style="scrollbar-width: none; -ms-overflow-style: none;">
                {vehicle.images.map((img, i) => (
                  <div class="min-w-full h-full flex-shrink-0 snap-center relative cursor-grab active:cursor-grabbing">
                    <Image 
                      src={img} 
                      alt={`${vehicle.name} - ${vehicle.unit} - Imagem ${i + 1}`}
                      class="absolute inset-0 w-full h-full object-cover"
                      quality="high"
                    />
                    <!-- Gradient overlay for text readability -->
                    <div class="absolute inset-0 bg-gradient-to-t from-navy-900/90 via-navy-900/20 to-transparent pointer-events-none"></div>
                  </div>
                ))}
              </div>

              <!-- Indicators (Visual only) -->
              <div class="absolute bottom-4 right-4 flex gap-1.5 z-10 pointer-events-none">
                {vehicle.images.map((_, i) => (
                  <div class="w-1.5 h-1.5 rounded-full bg-white/50 backdrop-blur-sm"></div>
                ))}
              </div>

              <!-- Unit Badge -->
              <div class="absolute top-4 right-4 bg-accent text-white font-bold text-xs px-3 py-1.5 rounded-sm uppercase tracking-wider z-10 shadow-sm pointer-events-none">
                {vehicle.unit}
              </div>
              <div class="absolute bottom-4 left-4 z-10 pointer-events-none">
                <span class="text-white font-bold text-xl drop-shadow-md">{vehicle.name}</span>
                <span class="block text-silver-300 text-sm drop-shadow-md">{vehicle.type}</span>
              </div>

              <!-- Swipe instruction hint -->
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-navy-900/60 backdrop-blur-md text-white px-4 py-2 rounded-full text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none flex items-center gap-2 shadow-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="11 17 6 12 11 7"></polyline><polyline points="18 17 13 12 18 7"></polyline></svg>
                Deslize para ver
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"></polyline><polyline points="6 17 11 12 6 7"></polyline></svg>
              </div>
            </div>

            <!-- Info area -->
            <div class="p-6">
              <p class="text-gray-500 text-sm leading-relaxed mb-4">
                {vehicle.description}
              </p>

              <div class="space-y-3">
                <div class="bg-white border border-silver-200 rounded-sm p-3">
                  <span class="text-[10px] font-medium text-silver-400 uppercase tracking-widest block">Especificação</span>
                  <span class="text-navy font-bold text-sm">{vehicle.spec}</span>
                </div>
                <div class="bg-white border border-silver-200 rounded-sm p-3">
                  <span class="text-[10px] font-medium text-silver-400 uppercase tracking-widest block">Capacidade</span>
                  <span class="text-accent font-bold text-sm">{vehicle.capacity}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>


  </div>
</section>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>
