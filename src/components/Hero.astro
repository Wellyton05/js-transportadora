---
// Hero.astro — Hero assimétrico com foco na marca e CTA WhatsApp
import { Image } from 'astro:assets';
import arteLogo from '../assets/artelogo.png';
---

<section id="home" class="relative min-h-screen flex items-center overflow-hidden bg-hero-gradient">
  <!-- Diagonal Lines Pattern Overlay -->
  <div class="absolute inset-0 bg-diagonal-lines opacity-40"></div>
  
  <!-- Grid Pattern -->
  <div class="absolute inset-0 bg-grid opacity-20"></div>

  <!-- Geometric Shapes -->
  <div class="absolute top-20 right-[10%] w-72 h-72 border border-silver-400/10 rotate-45 hidden lg:block"></div>
  <div class="absolute bottom-32 right-[20%] w-48 h-48 border border-accent/10 rotate-12 hidden lg:block"></div>
  <div class="absolute top-1/3 left-[5%] w-1 h-32 bg-gradient-to-b from-accent/40 to-transparent hidden lg:block"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 lg:py-0">
    <div class="grid lg:grid-cols-12 gap-8 items-center min-h-screen">
      <!-- Text Content — 7 columns -->
      <div class="lg:col-span-7 space-y-8">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/5 border border-silver-400/20 rounded-sm backdrop-blur-sm animate-fade-in">
          <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
          <span class="text-silver-200 text-xs font-medium uppercase tracking-widest">Itajaí — Santa Catarina</span>
        </div>

        <!-- Main Heading -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-black text-white leading-[1.05] animate-slide-up">
          Sua carga
          <span class="relative inline-block">
            <span class="relative z-10 text-accent">entregue</span>
            <span class="absolute bottom-1 left-0 w-full h-3 bg-accent/20 -rotate-1"></span>
          </span>
          <br />com cuidado e
          <br />agilidade.
        </h1>

        <!-- Subtitle -->
        <p class="text-silver-300 text-lg sm:text-xl max-w-xl leading-relaxed animate-fade-in" style="animation-delay: 0.3s;">
          Transporte de cargas com atendimento direto e descomplicado. Fale conosco e resolva seu frete agora mesmo.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 animate-fade-in" style="animation-delay: 0.5s;">
          <a
            href="https://wa.me/5547988602569"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
            id="hero-cta-quote"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Solicitar Orçamento
          </a>
          <a href="#services" class="btn-secondary" id="hero-cta-services">
            Nossos Serviços
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>

      <!-- Visual — 5 columns (decorativo geométrico, sem ícones genéricos) -->
      <div class="lg:col-span-5 hidden lg:flex items-center justify-center relative">
        <div class="relative w-full aspect-square max-w-lg">
          <!-- Decorative circles -->
          <div class="absolute inset-0 border-2 border-dashed border-silver-400/15 rounded-full animate-[spin_60s_linear_infinite]"></div>
          <div class="absolute inset-8 border border-silver-400/10 rounded-full"></div>
          
          <!-- Central — Logo emblema grande com caminhão -->
          <div class="absolute inset-4 bg-navy-500/10 rounded-full backdrop-blur-sm flex items-center justify-center p-4 border border-white/5">
            <Image 
              src={arteLogo} 
              alt="Caminhão e Logo J.S Transportadora" 
              class="w-full h-full object-contain drop-shadow-2xl transition-transform duration-700 hover:scale-105"
              loading="eager"
              quality="max"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Diagonal Bottom Cut -->
  <div class="absolute bottom-0 left-0 w-full h-24 bg-white" style="clip-path: polygon(0 100%, 100% 0, 100% 100%);"></div>
</section>
